# Runtime DB connection — app connects as a NON-superuser role so Postgres RLS is enforced.
DATABASE_URL=postgres://app_user:app_password@localhost:5432/edtech_doc_editor

# Migration/admin connection — owner role; runs drizzle-kit + migrate (creates roles, RLS policies).
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/edtech_doc_editor

# Auth.js (NextAuth v5) — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Public base URL of the app.
NEXTAUTH_URL=http://localhost:3000
